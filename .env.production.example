# .env.production.example
# Example environment variables for production

DATABASE_URL=
REDIS_URL=
# Note: For the heavy worker on Server B, DATABASE_URL and REDIS_URL must point
# to Server A's public endpoints with SSL (not internal Docker hostnames).

# HCA OAuth
HCA_CLIENT_ID=
HCA_CLIENT_SECRET=

# Slack bot token for profile sync
SLACK_BOT_TOKEN=
# Slack OAuth app credentials (for custom fallout pfp)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Lapse OAuth
LAPSE_CLIENT_ID=
LAPSE_CLIENT_SECRET=
LAPSE_PROGRAM_KEY=

# Geocoding API (Hack Club service)
GEOCODER_API_KEY=

# Sentry error + performance monitoring
SENTRY_DSN=
# Optional — required at BUILD time for @sentry/vite-plugin to upload source maps.
# Without these, prod stack traces in Sentry are minified.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# Optional — git SHA tagged on source map uploads + Sentry events. Auto-detected from git
# at build time when unset; set explicitly for Docker builds where .git is unavailable.
# SENTRY_RELEASE=

# Required for Active Record encryption
RAILS_MASTER_KEY=

# Cloudflare R2 (Active Storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# Loops.so (Action Mailer)
LOOPS_API_KEY=
MAILER_FROM=
APP_HOST=

# YouTube Data API v3 (for fetching video metadata)
YOUTUBE_API_KEY=

# yt-dlp cookies for YouTubeTimelapseService. Without it, server-IP downloads usually hit YouTube's
# "confirm you're not a bot" wall. Export from a logged-in (burner) Google account, then base64 it
# into a SINGLE line (env values must be one-lined):
#     base64 < cookies.txt | tr -d '\n'        # macOS/Linux
# Paste the result as the value. The worker base64-decodes it to a 0600 temp file per download.
# Runs on the WORKER (heavy queue) — set it in the worker's environment.
YT_DLP_COOKIES=

# External API key for /api/v1 endpoints
EXTERNAL_API_KEY=

# https://attend.hackclub.com/api/v1/events/fallout/participants
ATTEND_API_KEY=

# Airtable table id for syncing event-ticket holders (leave empty to skip that sync)
AIRTABLE_EVENT_TICKETS_TABLE_ID=

# Optional: URL to ping for uptime monitoring (e.g., BetterStack, UptimeRobot)
# UPTIME_WORKER_PING_URL=

PROFESSOR_API_SECRET=